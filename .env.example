# Firebase configuration — copy this file to `.env` and fill in the values.
# You can find them in the Firebase console:
#   Project settings (gear icon)  →  General  →  Your apps  →  Web app  →  SDK setup and configuration  →  Config
#
# These keys are safe to expose in client apps (Firebase identifies the project,
# not the caller) — the real security happens via Firebase Authentication rules
# and Security Rules. Still, treat `.env` as local-only and do not commit it.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# Optional (web analytics)
FIREBASE_MEASUREMENT_ID=

# Optional — only needed when building for iOS / macOS
FIREBASE_IOS_BUNDLE_ID=
